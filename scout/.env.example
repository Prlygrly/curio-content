# Copy this file to `scout/.env` and fill in keys as needed. `npm run scout` loads it
# automatically (via --env-file-if-exists). It is git-ignored and read ONLY by the
# Scout — never shipped to the browser.

# Optional: a free NASA key (https://api.nasa.gov) gives more headroom than DEMO_KEY.
# If unset, the Scout falls back to the key in scout/config.json (DEMO_KEY).
NASA_API_KEY=

# Optional (added later): a free Google AI Studio key for nicer summaries.
# v1 works with ZERO AI — leave this blank until we wire the Gemini summarizer.
GEMINI_API_KEY=
